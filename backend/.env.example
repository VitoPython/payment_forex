# Upstream BILLmanager-style pricelist proxy.
UPSTREAM_URL=https://api.zomrodev.online/v1/api/proxy/

# Datacenters requested from upstream (Poland, Netherlands, Germany, USA).
DATACENTERS=12,17,19,21

# fgroup_2 tag that marks a forex_server tariff.
FOREX_GROUP_TAG=9

# In-process cache lifetime for the upstream pricelist (seconds).
CACHE_TTL_SECONDS=120

# Allowed CORS origins (the frontend), comma-separated.
CORS_ORIGINS=http://localhost:3000
