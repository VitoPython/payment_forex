# Internal backend URL used by SSR and the /api proxy (Next.js rewrites).
# For a bare `next dev` with the backend on localhost this default is fine.
API_BASE_URL_INTERNAL=http://localhost:8000

# Optional: override the client API base URL. Leave unset to use the same
# origin (recommended — the app proxies /api to the backend).
# NEXT_PUBLIC_API_BASE_URL=
